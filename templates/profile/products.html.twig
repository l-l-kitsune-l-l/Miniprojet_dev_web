{% extends 'base.html.twig' %}

{% block title %}Mes produits — Otaku Shop{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-box-seam"></i> Mes produits en vente</h1>
    <div>
        <a href="{{ path('app_product_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Nouveau produit
        </a>
        <a href="{{ path('app_profile') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Retour au profil
        </a>
    </div>
</div>

{% if products is empty %}
    <div class="alert alert-info">
        Vous n'avez aucun produit en vente.
        <a href="{{ path('app_product_new') }}">Créer votre première annonce</a>
    </div>
{% else %}
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Nom</th>
                    <th>Prix</th>
                    <th>Stock</th>
                    <th>Catégorie</th>
                    <th>Tag</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for product in products %}
                    <tr>
                        <td class="fw-semibold">{{ product.name }}</td>
                        <td>{{ product.price|number_format(2, ',', ' ') }} €</td>
                        <td>
                            {{ product.stock }}
                            {% if product.stock <= product.stockThreshold %}
                                <span class="badge bg-warning text-dark">Faible</span>
                            {% endif %}
                        </td>
                        <td>{{ product.category ? product.category.name : '—' }}</td>
                        <td>{{ product.tag ? product.tag|capitalize : '—' }}</td>
                        <td>
                            {% if product.active %}
                                <span class="badge bg-success">Actif</span>
                            {% else %}
                                <span class="badge bg-secondary">Inactif</span>
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ path('app_product_show', {id: product.id}) }}"
                               class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a href="{{ path('app_product_edit', {id: product.id}) }}"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}