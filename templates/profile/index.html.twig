{% extends 'base.html.twig' %}

{% block title %}Mon profil — Otaku Shop{% endblock %}

{% block body %}
<div class="row">
    {# ===== SIDEBAR ===== #}
    <div class="col-lg-3 mb-4">
        <div class="card shadow-sm">
            <div class="card-body text-center">
                <div class="mb-3">
                    {% if user.avatar %}
                        <img src="{{ asset(user.avatar) }}" alt="Avatar"
                             class="rounded-circle" width="100" height="100">
                    {% else %}
                        <i class="bi bi-person-circle" style="font-size: 5rem; color: #6c757d;"></i>
                    {% endif %}
                </div>
                <h5>{{ user.pseudo }}</h5>
                <p class="text-muted">{{ user.firstName }} {{ user.lastName }}</p>
                <p class="text-muted"><small>{{ user.email }}</small></p>
                <span class="badge bg-{% if is_granted('ROLE_ADMIN') %}danger{% else %}primary{% endif %}">
                    {% if is_granted('ROLE_ADMIN') %}Admin{% else %}Membre{% endif %}
                </span>
            </div>
        </div>

        {# Menu latéral #}
        <div class="list-group mt-3 shadow-sm">
            <a href="{{ path('app_profile') }}"
               class="list-group-item list-group-item-action active">
                <i class="bi bi-person"></i> Mon profil
            </a>
            <a href="{{ path('app_profile_edit') }}"
               class="list-group-item list-group-item-action">
                <i class="bi bi-pencil"></i> Modifier le profil
            </a>
            <a href="{{ path('app_profile_products') }}"
               class="list-group-item list-group-item-action">
                <i class="bi bi-box-seam"></i> Mes produits
                <span class="badge bg-secondary float-end">{{ user.products|length }}</span>
            </a>
            <a href="{{ path('app_profile_orders') }}"
               class="list-group-item list-group-item-action">
                <i class="bi bi-cart3"></i> Mes commandes
                <span class="badge bg-secondary float-end">{{ user.orders|length }}</span>
            </a>
            <a href="{{ path('app_profile_favorites') }}"
               class="list-group-item list-group-item-action">
                <i class="bi bi-heart"></i> Mes favoris
                <span class="badge bg-secondary float-end">{{ user.favorites|length }}</span>
            </a>
            <a href="{{ path('app_profile_reviews') }}"
               class="list-group-item list-group-item-action">
                <i class="bi bi-star"></i> Avis reçus
                <span class="badge bg-secondary float-end">{{ user.receivedReviews|length }}</span>
            </a>
        </div>
    </div>

    {# ===== CONTENU PRINCIPAL ===== #}
    <div class="col-lg-9">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">
                <h4 class="mb-0"><i class="bi bi-person"></i> Mon profil</h4>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <table class="table table-borderless">
                            <tr>
                                <th><i class="bi bi-person"></i> Pseudo</th>
                                <td>{{ user.pseudo }}</td>
                            </tr>
                            <tr>
                                <th><i class="bi bi-envelope"></i> Email</th>
                                <td>{{ user.email }}</td>
                            </tr>
                            <tr>
                                <th><i class="bi bi-card-text"></i> Nom</th>
                                <td>{{ user.firstName }} {{ user.lastName }}</td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table class="table table-borderless">
                            <tr>
                                <th><i class="bi bi-palette"></i> Thème</th>
                                <td>{{ user.theme == 'dark' ? 'Sombre' : 'Clair' }}</td>
                            </tr>
                            <tr>
                                <th><i class="bi bi-globe"></i> Langue</th>
                                <td>{{ user.locale == 'fr' ? 'Français' : 'English' }}</td>
                            </tr>
                            <tr>
                                <th><i class="bi bi-calendar"></i> Inscrit le</th>
                                <td>{{ user.createdAt|date('d/m/Y') }}</td>
                            </tr>
                        </table>
                    </div>
                </div>

                <a href="{{ path('app_profile_edit') }}" class="btn btn-primary">
                    <i class="bi bi-pencil"></i> Modifier mon profil
                </a>
            </div>
        </div>

        {# ===== RÉSUMÉ ===== #}
        <div class="row mt-4">
            <div class="col-md-4 mb-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <h2 class="text-primary">{{ user.products|length }}</h2>
                        <p class="text-muted mb-0">Produits en vente</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <h2 class="text-success">{{ user.orders|length }}</h2>
                        <p class="text-muted mb-0">Commandes</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <h2 class="text-danger">{{ user.favorites|length }}</h2>
                        <p class="text-muted mb-0">Favoris</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}