{% extends 'base.html.twig' %}

{% block title %}Avis reçus — Otaku Shop{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-star"></i> Avis reçus</h1>
    <a href="{{ path('app_profile') }}" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Retour au profil
    </a>
</div>

{% if reviews is empty %}
    <div class="alert alert-info">Vous n'avez reçu aucun avis pour le moment.</div>
{% else %}
    {# Calcul de la moyenne #}
    {% set totalRating = 0 %}
    {% for review in reviews %}
        {% set totalRating = totalRating + review.rating %}
    {% endfor %}
    {% set avgRating = totalRating / reviews|length %}

    <div class="card shadow-sm mb-4">
        <div class="card-body text-center">
            <h3>
                <span class="text-warning">
                    {% for i in 1..5 %}
                        {% if i <= avgRating|round %}
                            <i class="bi bi-star-fill"></i>
                        {% else %}
                            <i class="bi bi-star"></i>
                        {% endif %}
                    {% endfor %}
                </span>
            </h3>
            <p class="text-muted mb-0">
                {{ avgRating|number_format(1) }} / 5 — {{ reviews|length }} avis
            </p>
        </div>
    </div>

    <div class="row row-cols-1 g-3">
        {% for review in reviews %}
            <div class="col">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <div>
                                <i class="bi bi-person"></i>
                                <strong>{{ review.author.pseudo }}</strong>
                                <small class="text-muted ms-2">{{ review.createdAt|date('d/m/Y') }}</small>
                            </div>
                            <span class="text-warning">
                                {% for i in 1..5 %}
                                    {% if i <= review.rating %}
                                        <i class="bi bi-star-fill"></i>
                                    {% else %}
                                        <i class="bi bi-star"></i>
                                    {% endif %}
                                {% endfor %}
                            </span>
                        </div>
                        <p class="mb-0">{{ review.content }}</p>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}