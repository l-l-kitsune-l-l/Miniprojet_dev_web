{% extends 'base.html.twig' %}

{% block title %}{{ category.name }} — Otaku Shop{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-tag"></i> {{ category.name }}</h1>
    <a href="{{ path('app_category_index') }}" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
</div>

{% if category.description %}
    <p class="lead">{{ category.description }}</p>
{% endif %}

<h3 class="mt-4 mb-3">Produits de cette catégorie</h3>

{% set activeProducts = category.products|filter(p => p.active) %}

{% if activeProducts is empty %}
    <div class="alert alert-info">Aucun produit dans cette catégorie.</div>
{% else %}
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Nom</th>
                    <th>Prix</th>
                    <th>Stock</th>
                    <th>Tag</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for product in activeProducts %}
                    <tr>
                        <td class="fw-semibold">{{ product.name }}</td>
                        <td>{{ product.price|number_format(2, ',', ' ') }} €</td>
                        <td>
                            {{ product.stock }}
                            {% if product.stock <= product.stockThreshold %}
                                <span class="badge bg-warning text-dark">Faible</span>
                            {% endif %}
                        </td>
                        <td>{{ product.tag ? product.tag|capitalize : '—' }}</td>
                        <td>
                            <a href="{{ path('app_product_show', {id: product.id}) }}" class="btn btn-sm btn-outline-secondary">
                                Voir
                            </a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}