{% extends 'base.html.twig' %}

{% block title %}{{ 'order_title'|trans({'reference': order.reference}) }} — Otaku Shop{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-receipt"></i> {{ 'order_title'|trans({'reference': order.reference}) }}</h1>
        <a href="{{ path('app_order_index') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> {{ 'return_button'|trans }}
        </a>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5>{{ 'order_information'|trans }}</h5>
                    <p><strong>{{ 'buyer_label'|trans }}</strong> {{ order.buyer.pseudo }}</p>
                    <p>
                        <strong>{{ 'status_label'|trans }}</strong>
                        <span class="badge bg-{% if order.status == 'confirmed' %}success{% elseif order.status == 'pending' %}warning text-dark{% elseif order.status == 'shipped' %}primary{% else %}danger{% endif %}">
                        {{ ('order_status.' ~ order.status)|trans }}
                    </span>
                    </p>
                    <p><strong>{{ 'date_label'|trans }}</strong> {{ order.createdAt|date('d/m/Y à H:i') }}</p>
                    <p class="h4 text-primary">
                        <strong>{{ 'total_label'|trans }} {{ order.total|number_format(2, ',', ' ') }} €</strong>
                    </p>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <table class="table table-striped align-middle mb-0">
                        <thead class="table-dark">
                        <tr>
                            <th>{{ 'table_header_product'|trans }}</th>
                            <th>{{ 'table_header_unit_price'|trans }}</th>
                            <th>{{ 'table_header_quantity'|trans }}</th>
                            <th>{{ 'table_header_subtotal'|trans }}</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for line in order.orderLines %}
                            <tr>
                                <td class="fw-semibold">{{ line.product.name }}</td>
                                <td>{{ line.unitPrice|number_format(2, ',', ' ') }} €</td>
                                <td>{{ line.quantity }}</td>
                                <td>{{ (line.unitPrice * line.quantity)|number_format(2, ',', ' ') }} €</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                        <tfoot class="table-light">
                        <tr>
                            <th colspan="3" class="text-end">{{ 'total_label'|trans }}</th>
                            <th>{{ order.total|number_format(2, ',', ' ') }} €</th>
                        </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}