{% extends 'base.html.twig' %}

{% block title %}Commande {{ order.reference }} — Otaku Shop{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-receipt"></i> Commande {{ order.reference }}</h1>
    <a href="{{ path('app_order_index') }}" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
</div>

<div class="row">
    <div class="col-lg-4 mb-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5>Informations</h5>
                <p><strong>Acheteur :</strong> {{ order.buyer.pseudo }}</p>
                <p>
                    <strong>Statut :</strong>
                    <span class="badge bg-{% if order.status == 'confirmed' %}success{% elseif order.status == 'pending' %}warning text-dark{% elseif order.status == 'shipped' %}primary{% else %}danger{% endif %}">
                        {{ order.status }}
                    </span>
                </p>
                <p><strong>Date :</strong> {{ order.createdAt|date('d/m/Y à H:i') }}</p>
                <p class="h4 text-primary"><strong>Total : {{ order.total|number_format(2, ',', ' ') }} €</strong></p>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Produit</th>
                            <th>Prix unitaire</th>
                            <th>Quantité</th>
                            <th>Sous-total</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for line in order.orderLines %}
                            <tr>
                                <td class="fw-semibold">{{ line.product.name }}</td>
                                <td>{{ line.unitPrice|number_format(2, ',', ' ') }} €</td>
                                <td>{{ line.quantity }}</td>
                                <td>{{ (line.unitPrice * line.quantity)|number_format(2, ',', ' ') }} €</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <th colspan="3" class="text-end">Total</th>
                            <th>{{ order.total|number_format(2, ',', ' ') }} €</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}