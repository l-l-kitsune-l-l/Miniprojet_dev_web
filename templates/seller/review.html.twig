{% extends 'base.html.twig' %}

{% block title %}Avis sur {{ seller.pseudo }} — Otaku Shop{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">
                    <i class="bi bi-chat-dots"></i> Laisser un avis sur {{ seller.pseudo }}
                </h4>
            </div>
            <div class="card-body">
                {{ form_start(form) }}
                    {{ form_widget(form) }}
                    <div class="d-flex justify-content-between mt-4">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-lg"></i> Publier
                        </button>
                        <a href="{{ path('app_seller_show', {id: seller.id}) }}" class="btn btn-secondary">
                            Annuler
                        </a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}