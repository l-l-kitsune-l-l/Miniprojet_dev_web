{% extends 'base.html.twig' %}

{% block title %}Produits — Otaku Shop{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-box-seam"></i> Produits</h1>
    <a href="{{ path('app_product_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nouveau produit
    </a>
    {% if is_granted('ROLE_USER') %}
        <a href="{{ path('app_product_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Vendre un article
        </a>
    {% endif %}
</div>

{# ===== RECHERCHE ===== #}
<div class="card shadow-sm mb-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center"
         data-bs-toggle="collapse" data-bs-target="#searchForm"
         style="cursor: pointer;">
        <h5 class="mb-0"><i class="bi bi-search"></i> Recherche avancée</h5>
        <i class="bi bi-chevron-down"></i>
    </div>
    <div class="collapse" id="searchForm">
        <div class="card-body">
            {{ form_start(searchForm, {'attr': {'class': 'row g-3'}}) }}

                {# Ligne 1 : Nom + Catégorie + Pays #}
                <div class="col-md-4">
                    {{ form_row(searchForm.name) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(searchForm.category) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(searchForm.country) }}
                </div>

                {# Ligne 2 : Prix min + Prix max + Tag #}
                <div class="col-md-3">
                    {{ form_row(searchForm.minPrice) }}
                </div>
                <div class="col-md-3">
                    {{ form_row(searchForm.maxPrice) }}
                </div>
                <div class="col-md-3">
                    {{ form_row(searchForm.tag) }}
                </div>
                <div class="col-md-3">
                    {{ form_row(searchForm.sortBy) }}
                </div>

                {# Ligne 3 : En stock + Boutons #}
                <div class="col-md-4">
                    {{ form_row(searchForm.inStock) }}
                </div>
                <div class="col-md-8 d-flex align-items-end justify-content-end gap-2">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-search"></i> Rechercher
                    </button>
                    <a href="{{ path('app_product_index') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg"></i> Réinitialiser
                    </a>
                </div>

            {{ form_end(searchForm) }}
        </div>
    </div>
</div>

{# ===== NB RÉSULTATS ===== #}
<p class="text-muted mb-3">
    <i class="bi bi-list-ul"></i>
    {{ products|length }} produit{{ products|length > 1 ? 's' : '' }} trouvé{{ products|length > 1 ? 's' : '' }}
</p>

{# ===== LISTE DES PRODUITS ===== #}
{% if products is empty %}
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> Aucun produit ne correspond à votre recherche.
        <a href="{{ path('app_product_index') }}">Voir tous les produits</a>
    </div>
{% else %}
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        {% for product in products %}
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        {# Tag badge #}
                        {% if product.tag %}
                            <span class="badge bg-{% if product.tag == 'promo' %}danger{% elseif product.tag == 'nouveau' %}primary{% elseif product.tag == 'best' %}success{% else %}warning text-dark{% endif %} mb-2">
                                {{ product.tag|capitalize }}
                            </span>
                        {% endif %}

                        <h5 class="card-title">{{ product.name }}</h5>

                        <p class="card-text text-muted">
                            {{ product.description|length > 80 ? product.description|slice(0, 80) ~ '...' : product.description }}
                        </p>

                        <div class="d-flex justify-content-between align-items-center">
                            <span class="h5 text-primary mb-0">{{ product.price|number_format(2, ',', ' ') }} €</span>

                            {% if product.stock <= product.stockThreshold %}
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-exclamation-triangle"></i> Stock faible ({{ product.stock }})
                                </span>
                            {% elseif product.stock == 0 %}
                                <span class="badge bg-danger">Rupture</span>
                            {% else %}
                                <span class="badge bg-success">
                                    Stock : {{ product.stock }}
                                </span>
                            {% endif %}
                        </div>

                        <div class="mt-2">
                            {% if product.category %}
                                <small class="text-muted">
                                    <i class="bi bi-tag"></i> {{ product.category.name }}
                                </small>
                            {% endif %}
                            {% if product.country %}
                                <small class="text-muted ms-2">
                                    <i class="bi bi-geo-alt"></i> {{ product.country }}
                                </small>
                            {% endif %}
                        </div>

                        {# Vendeur #}
                        {% if product.seller %}
                            <div class="mt-2">
                                <small class="text-muted">
                                    <i class="bi bi-person"></i> {{ product.seller.pseudo }}
                                </small>
                            </div>
                        {% endif %}
                    </div>

                    <div class="card-footer bg-white d-flex justify-content-between">
                        <a href="{{ path('app_product_show', {id: product.id}) }}" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-eye"></i> Voir
                        </a>
                        <div>
                            {# Bouton favori rapide #}
                            {% if app.user %}
                                {% if app.user.favorites.contains(product) %}
                                    <form method="post" action="{{ path('app_favorite_remove', {id: product.id}) }}" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-heart-fill"></i>
                                        </button>
                                    </form>
                                {% else %}
                                    <form method="post" action="{{ path('app_favorite_add', {id: product.id}) }}" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-heart"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            {% endif %}

                            {# Bouton modifier (si c'est mon produit) #}
                            {% if app.user and app.user == product.seller %}
                                <a href="{{ path('app_product_edit', {id: product.id}) }}" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}