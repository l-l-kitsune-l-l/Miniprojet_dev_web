{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} — Otaku Shop{% endblock %}

{% block body %}
<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <h1>{{ product.name }}</h1>
                    {% if product.tag %}
                        <span class="badge bg-{% if product.tag == 'promo' %}danger{% elseif product.tag == 'nouveau' %}primary{% elseif product.tag == 'best' %}success{% else %}warning text-dark{% endif %} fs-6">
                            {{ product.tag|capitalize }}
                        </span>
                    {% endif %}
                </div>

                <p class="lead">{{ product.description }}</p>

                <hr>

                <div class="row">
                    <div class="col-md-6">
                        <table class="table table-borderless">
                            <tr>
                                <th><i class="bi bi-currency-euro"></i> Prix</th>
                                <td class="h4 text-primary">{{ product.price|number_format(2, ',', ' ') }} €</td>
                            </tr>
                            <tr>
                                <th><i class="bi bi-box"></i> Stock</th>
                                <td>
                                    {{ product.stock }}
                                    {% if product.stock <= product.stockThreshold %}
                                        <span class="badge bg-warning text-dark">Faible</span>
                                    {% endif %}
                                </td>
                            </tr>
                            <tr>
                                <th><i class="bi bi-tag"></i> Catégorie</th>
                                <td>{{ product.category ? product.category.name : '—' }}</td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table class="table table-borderless">
                            <tr>
                                <th><i class="bi bi-geo-alt"></i> Pays</th>
                                <td>{{ product.country ?? '—' }}</td>
                            </tr>
                            <tr>
                                <th><i class="bi bi-calendar"></i> Expiration</th>
                                <td>{{ product.expirationDate ? product.expirationDate|date('d/m/Y') : '—' }}</td>
                            </tr>
                            <tr>
                                <th><i class="bi bi-clock"></i> Créé le</th>
                                <td>{{ product.createdAt|date('d/m/Y à H:i') }}</td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card-footer d-flex justify-content-between">
                <a href="{{ path('app_product_index') }}" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Retour
                </a>
                <div>
                {% if app.user %}
                     {% if app.user.favorites.contains(product) %}
                        <form method="post" action="{{ path('app_favorite_remove', {id: product.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('favorite' ~ product.id) }}">
                                <button type="submit" class="btn btn-danger">
                                    <i class="bi bi-heart-fill"></i> Retirer des favoris
                                </button>
                        </form>
                    {% else %}
                        <form method="post" action="{{ path('app_favorite_add', {id: product.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('favorite' ~ product.id) }}">
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="bi bi-heart"></i> Ajouter aux favoris
                            </button>
                        </form>
                    {% endif %}
                {% endif %}

                {% if app.user and app.user != product.seller %}
                    {% if product.stock > 0 %}
                     <form method="post" action="{{ path('app_product_buy', {id: product.id}) }}" class="d-inline"
                            onsubmit="return confirm('Confirmer l\'achat ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('buy' ~ product.id) }}">
                         <div class="input-group d-inline-flex" style="width: auto;">
                            <input type="number" name="quantity" value="1" min="1" max="{{ product.stock }}"
                                class="form-control form-control-sm" style="width: 60px;">
                            <button type="submit" class="btn btn-success btn-sm">
                                <i class="bi bi-cart-plus"></i> Acheter
                            </button>
                         </div>
                    </form>
                {% else %}
                    <span class="btn btn-secondary btn-sm disabled">
                        <i class="bi bi-x-circle"></i> Rupture de stock
                    </span>
                {% endif %}
            {% endif %}
                    <a href="{{ path('app_product_edit', {id: product.id}) }}" class="btn btn-primary">
                        <i class="bi bi-pencil"></i> Modifier
                    </a>
                    <form method="post" action="{{ path('app_product_delete', {id: product.id}) }}" class="d-inline"
                          onsubmit="return confirm('Supprimer ce produit ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                        <button class="btn btn-danger">
                            <i class="bi bi-trash"></i> Supprimer
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}